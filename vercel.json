{
  "rewrites": [{ "source": "/api/(.*)", "destination": "/api/$1" }],
  "crons": [
    {
      "path": "/api/cron-briefing",
      "schedule": "0 8 * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" }
      ]
    }
  ]
}
